# devmind API Keys — copy this file to .env and fill in your key

# Option 1 (Recommended, FREE): OpenRouter
# Sign up free at https://openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=your_openrouter_key_here

# Option 2: Gemini (free daily quota)
# GEMINI_API_KEY=your_key

# Option 3: Groq (free, limited context)
# GROQ_API_KEY=your_key